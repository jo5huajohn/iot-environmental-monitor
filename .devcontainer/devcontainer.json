{
	"name": "Zephyr Dev Container",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"runArgs": [
		"-v", "/dev:/dev",
		"--privileged"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-vscode.cpptools",
				"nordic-semiconductor.nrf-connect-extension-pack",
				"timonwong.shellcheck"
			]
		}
	}
}
